{
  "expo": {
    "name": "Nido",
    "slug": "nido",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "scheme": "nido",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "art.drama.nido"
    },
    "android": {
      "package": "art.drama.nido",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Nido",
      "shortName": "Nido",
      "description": "Tu casa, en orden. Sin discusiones.",
      "themeColor": "#ffffff",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "820859ad-223c-4fd6-8ab0-d7654cfea101"
      }
    },
    "owner": "franmc20si"
  }
}
